generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  VIEWER
}

enum FolderVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files         File[]
  downloadLogs  DownloadLog[]

  @@index([email])
  @@index([role])
}

model Folder {
  id         String           @id @default(cuid())
  name       String
  parentId   String?
  visibility FolderVisibility @default(PUBLIC)
  sortOrder  Int              @default(0)
  starred    Boolean          @default(false)
  deletedAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  parent   Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children Folder[] @relation("FolderHierarchy")
  files    File[]

  @@unique([name, parentId])
  @@index([parentId])
  @@index([visibility])
  @@index([starred])
  @@index([deletedAt])
}

model File {
  id            String    @id @default(cuid())
  name          String
  originalName  String
  mimeType      String
  size          BigInt
  extension     String
  s3Key         String    @unique
  folderId      String?
  uploadedBy    String
  downloadCount Int       @default(0)
  starred       Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  folder       Folder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploader     User          @relation(fields: [uploadedBy], references: [id])
  downloadLogs DownloadLog[]

  @@index([folderId])
  @@index([uploadedBy])
  @@index([name])
  @@index([mimeType])
  @@index([createdAt])
  @@index([starred])
  @@index([deletedAt])
}

model DownloadLog {
  id           String   @id @default(cuid())
  fileId       String
  userId       String?
  ipAddress    String?
  userAgent    String?
  downloadedAt DateTime @default(now())

  file File  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([fileId])
  @@index([downloadedAt])
}
